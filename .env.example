NEXT_PUBLIC_SITE_URL=https://agendacryptoo.com
# Legado: usado somente pelo fluxo LNURL-auth preservado para rollback e testes históricos.
LNURL_AUTH_BASE_URL=https://auth.agendacryptoo.com
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/elas_recebem_hoje

# Migração gradual do estado público. LEGACY permanece o padrão seguro.
LRP_ORIGINATION_MODE=LEGACY
LRP_ORIGINATOR_PUBKEY=

# Breez Liquid mainnet permanece desligado sem autorização operacional explícita.
BREEZ_NETWORK=mainnet
BREEZ_ENABLE_MAINNET=false
BREEZ_ENABLE_CONTROLLED_DEMO=false
BREEZ_ENABLE_AUDIT_PROBES=false
BREEZ_API_KEY=
BREEZ_MNEMONIC=
BREEZ_WORKING_DIR=.breez-mainnet
BREEZ_MAINNET_LBTC_ASSET_ID=6f0279e9ed041c3d710a9f57d0c02928416460c4b722ae3457a11eec381c526d
BREEZ_MAINNET_USDT_ASSET_ID=ce091c998b83c78bb71a632313ba3760f1763d9cfcffae02258ffa9865a37bd2
BREEZ_MAX_RECEIVE_FEE_SATS=1000
BREEZ_MAX_INVOICE_SATS=1000
BREEZ_MAX_SESSION_SATS=5000
BREEZ_MAX_HOT_WALLET_SATS=10000
BREEZ_AUDIT_MAX_SLIPPAGE_BPS=100

# Publique atestações somente por um signer institucional externo; nunca configure nsec aqui.
NOSTR_RELAYS=wss://relay.damus.io/,wss://nos.lol/,wss://relay.primal.net/,wss://relay.nostr.band/,wss://offchain.pub/
